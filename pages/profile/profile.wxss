.player-card {
  position: relative;
  overflow: hidden;
  padding-left: 150rpx;
}

.player-card::after {
  content: "";
  position: absolute;
  right: -70rpx;
  bottom: -70rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(241, 196, 15, 0.16);
}

.avatar-large {
  position: absolute;
  left: 28rpx;
  top: 34rpx;
  width: 96rpx;
  height: 96rpx;
  border: 3rpx solid rgba(241, 196, 15, 0.65);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.card-score {
  position: absolute;
  right: 28rpx;
  top: 34rpx;
  color: #f1c40f;
  font-size: 72rpx;
  font-weight: 900;
  text-shadow: 0 0 24rpx rgba(241, 196, 15, 0.36);
}

.panel {
  margin-top: 24rpx;
}

.avatar-editor {
  padding: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
}

.avatar-choose-btn,
.avatar-privacy-btn {
  align-items: center;
  background: transparent;
  color: #f7f4ea;
  display: flex;
  gap: 20rpx;
  margin: 0;
  padding: 0;
  text-align: left;
  width: 100%;
}

.avatar-choose-btn::after,
.avatar-privacy-btn::after {
  border: 0;
}

.avatar-choose-copy {
  flex: 1;
  min-width: 0;
}

.avatar-preview {
  flex-shrink: 0;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.form-label {
  margin: 20rpx 0 10rpx;
  color: #f1c40f;
  font-size: 24rpx;
  font-weight: 900;
}

.position-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}

.position-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 68rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #8d98a8;
  background: rgba(255, 255, 255, 0.04);
  font-size: 22rpx;
}

.position-chip checkbox {
  display: none;
}

.position-chip.active {
  color: #071018;
  border-color: #f1c40f;
  background: #f1c40f;
  font-weight: 900;
}

.primary-btn {
  margin-top: 24rpx;
}
