.player-card {
  position: relative;
  overflow: hidden;
  padding-left: 150rpx;
}

.player-card::after {
  content: "";
  position: absolute;
  right: -70rpx;
  bottom: -70rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(241, 196, 15, 0.16);
}

.avatar-large {
  position: absolute;
  left: 28rpx;
  top: 34rpx;
  width: 96rpx;
  height: 96rpx;
  border: 3rpx solid rgba(241, 196, 15, 0.65);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.card-score {
  position: absolute;
  right: 28rpx;
  top: 34rpx;
  color: #f1c40f;
  font-size: 72rpx;
  font-weight: 900;
  text-shadow: 0 0 24rpx rgba(241, 196, 15, 0.36);
}

.panel {
  margin-top: 24rpx;
}

.stats-panel {
  border-color: rgba(241, 196, 15, 0.28);
}

.summary-grid,
.average-grid {
  display: grid;
  gap: 12rpx;
}

.summary-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.summary-stat {
  min-width: 0;
  padding: 18rpx 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.035);
  text-align: center;
}

.summary-stat .stat-value {
  overflow: hidden;
  font-size: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-line {
  display: flex;
  justify-content: space-around;
  margin-top: 18rpx;
  padding: 16rpx;
  color: #fffaf0;
  background: rgba(0, 0, 0, 0.2);
  font-size: 25rpx;
  font-weight: 800;
}

.section-subtitle {
  margin: 26rpx 0 12rpx;
  color: #f1c40f;
  font-size: 24rpx;
  font-weight: 900;
}

.average-grid {
  grid-template-columns: repeat(5, minmax(0, 1fr));
}

.average-grid > view {
  min-width: 0;
  text-align: center;
}

.metric-value,
.metric-label {
  display: block;
}

.metric-value {
  overflow: hidden;
  color: #fffaf0;
  font-size: 27rpx;
  font-weight: 900;
  text-overflow: ellipsis;
}

.metric-label {
  margin-top: 4rpx;
  color: #8d98a8;
  font-size: 19rpx;
}

.totals-line,
.inline-empty {
  margin-top: 14rpx;
  color: #8d98a8;
  font-size: 22rpx;
}

.hero-summary,
.steam-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-chip,
.steam-id {
  padding: 10rpx 14rpx;
  border: 2rpx solid rgba(241, 196, 15, 0.2);
  border-radius: 8rpx;
  color: #d8c78f;
  background: rgba(241, 196, 15, 0.06);
  font-size: 21rpx;
}

.hero-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 210rpx;
}

.hero-chip-image,
.recent-hero-image {
  flex-shrink: 0;
  width: 76rpx;
  height: 46rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.06);
}

.hero-chip-copy {
  min-width: 0;
}

.hero-chip-copy text {
  display: block;
}

.hero-chip-copy text + text {
  margin-top: 4rpx;
  color: #8d98a8;
  font-size: 19rpx;
}

.recent-hero-image {
  width: 88rpx;
  height: 52rpx;
}

.personal-match {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.07);
}

.personal-match:first-child {
  border-top: 0;
}

.result-mark {
  flex-shrink: 0;
  width: 70rpx;
  padding: 8rpx 0;
  border-radius: 6rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 900;
}

.result-win {
  color: #071018;
  background: #f1c40f;
}

.result-loss {
  color: #fff;
  background: #b43843;
}

.personal-match-main {
  flex: 1;
  min-width: 0;
}

.match-arrow {
  flex-shrink: 0;
  color: #8d98a8;
  font-size: 42rpx;
}

.card-meta-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.avatar-editor {
  padding: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
}

.avatar-choose-btn,
.avatar-privacy-btn {
  align-items: center;
  background: transparent;
  color: #f7f4ea;
  display: flex;
  gap: 20rpx;
  margin: 0;
  padding: 0;
  text-align: left;
  width: 100%;
}

.avatar-choose-btn::after,
.avatar-privacy-btn::after {
  border: 0;
}

.avatar-choose-copy {
  flex: 1;
  min-width: 0;
}

.avatar-preview {
  flex-shrink: 0;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.form-label {
  margin: 20rpx 0 10rpx;
  color: #f1c40f;
  font-size: 24rpx;
  font-weight: 900;
}

.position-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}

.position-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 68rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #8d98a8;
  background: rgba(255, 255, 255, 0.04);
  font-size: 22rpx;
}

.position-chip checkbox {
  display: none;
}

.position-chip.active {
  color: #071018;
  border-color: #f1c40f;
  background: #f1c40f;
  font-weight: 900;
}

.primary-btn {
  margin-top: 24rpx;
}
