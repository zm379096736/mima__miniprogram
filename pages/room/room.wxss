.team-card {
  margin-bottom: 22rpx;
}

.admin-panel {
  border-color: rgba(230, 57, 70, 0.36);
}

.reset-competition-btn {
  margin-top: 14rpx;
}

.signup-panel .danger-btn,
.signup-panel .primary-btn,
.primary-btn {
  margin-top: 16rpx;
}

.time-picker {
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 8rpx;
  color: #f7efe0;
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
}

.check-row {
  align-items: center;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
}

.time-picker.read-only {
  color: rgba(247, 239, 224, 0.72);
}

.admin-score-editor {
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  margin-top: 28rpx;
  padding-top: 24rpx;
}

.admin-player-picker {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 8rpx;
  color: #f7efe0;
  margin-top: 14rpx;
  padding: 20rpx 22rpx;
}

.admin-score-editor .input {
  margin-top: 14rpx;
}

.admin-steam-editor {
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-top: 24rpx;
  padding-top: 22rpx;
}

.admin-steam-editor .input {
  margin-top: 14rpx;
}

.sponsor-admin {
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-top: 28rpx;
  padding-top: 24rpx;
}

.sponsor-add-row,
.sponsor-admin-row {
  align-items: center;
  display: flex;
  gap: 14rpx;
}

.sponsor-input,
.sponsor-admin-name {
  flex: 1;
  min-width: 0;
}

.sponsor-add-btn {
  flex-shrink: 0;
  margin-top: 0;
  width: 132rpx;
}

.sponsor-list {
  margin-top: 16rpx;
}

.sponsor-admin-row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  min-height: 72rpx;
}

.remove-player-btn {
  flex-shrink: 0;
  min-width: 82rpx;
  height: 48rpx;
  margin-left: 12rpx;
  padding: 0 14rpx;
  border: 2rpx solid rgba(230, 57, 70, 0.5);
  border-radius: 8rpx;
  color: #fffaf0;
  background: rgba(230, 57, 70, 0.16);
  font-size: 22rpx;
  line-height: 44rpx;
}

.remove-player-btn::after {
  border: 0;
}

.team-swap-panel {
  margin-bottom: 22rpx;
}

.round-rotation-panel {
  margin-bottom: 22rpx;
}

.rotation-names {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.swap-selection {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.team-select-btn {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 8rpx;
  color: #f7efe0;
  flex-shrink: 0;
  font-size: 22rpx;
  height: 48rpx;
  line-height: 46rpx;
  margin-left: 10rpx;
  min-width: 82rpx;
  padding: 0 12rpx;
}

.team-select-btn.selected {
  background: #ffd43b;
  border-color: #ffd43b;
  color: #151515;
}

.team-select-btn::after {
  border: 0;
}
