.team-card {
  margin-bottom: 22rpx;
}

.admin-panel {
  border-color: rgba(230, 57, 70, 0.36);
}

.signup-panel .danger-btn,
.signup-panel .primary-btn,
.primary-btn {
  margin-top: 16rpx;
}

.time-picker {
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 8rpx;
  color: #f7efe0;
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
}

.check-row {
  align-items: center;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
}
