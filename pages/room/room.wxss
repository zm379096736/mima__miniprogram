.team-card {
  margin-bottom: 22rpx;
}

.admin-panel {
  border-color: rgba(230, 57, 70, 0.36);
}

.signup-panel .danger-btn,
.signup-panel .primary-btn,
.primary-btn {
  margin-top: 16rpx;
}

.time-picker {
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 8rpx;
  color: #f7efe0;
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
}

.check-row {
  align-items: center;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
}

.time-picker.read-only {
  color: rgba(247, 239, 224, 0.72);
}

.admin-score-editor {
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  margin-top: 28rpx;
  padding-top: 24rpx;
}

.admin-player-picker {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 8rpx;
  color: #f7efe0;
  margin-top: 14rpx;
  padding: 20rpx 22rpx;
}

.admin-score-editor .input {
  margin-top: 14rpx;
}

.remove-player-btn {
  flex-shrink: 0;
  min-width: 82rpx;
  height: 48rpx;
  margin-left: 12rpx;
  padding: 0 14rpx;
  border: 2rpx solid rgba(230, 57, 70, 0.5);
  border-radius: 8rpx;
  color: #fffaf0;
  background: rgba(230, 57, 70, 0.16);
  font-size: 22rpx;
  line-height: 44rpx;
}

.remove-player-btn::after {
  border: 0;
}
