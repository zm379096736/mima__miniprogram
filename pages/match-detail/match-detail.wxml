<view class="screen">
  <view wx:if="{{loading}}" class="empty-panel">正在加载战绩...</view>

  <block wx:if="{{detail}}">
    <view class="hero">
      <view class="eyebrow">{{detail.imported ? 'DOTA MATCH' : 'MIMA INHOUSE'}}</view>
      <view class="title">{{detail.title}}</view>
      <view class="subtitle">胜方 {{detail.winner}}</view>
      <view class="detail-meta">
        <text>{{detail.sourceText}}</text>
        <text>{{detail.startTimeText}}</text>
        <text>时长 {{detail.durationText}}</text>
      </view>
    </view>

    <view class="section team-card radiant">
      <view class="team-head">
        <text>天辉</text>
        <text class="team-score">自评 {{detail.radiantScore}}</text>
        <text wx:if="{{detail.winnerSide === 'radiant' || detail.radiantWin}}" class="badge blue">胜利</text>
      </view>
      <view wx:for="{{detail.radiant}}" wx:key="playerId" class="player-row">
        <image wx:if="{{detail.imported}}" class="hero-portrait" src="{{item.heroImage}}" mode="aspectFill"></image>
        <image class="player-avatar" src="{{item.avatarSrc}}" mode="aspectFill"></image>
        <view class="player-main">
          <view class="player-name">{{detail.imported ? item.heroName : item.name}}</view>
          <view wx:if="{{detail.imported}}" class="player-meta">{{item.name}} · 自评分 {{item.score}}</view>
          <view wx:if="{{detail.imported}}" class="player-meta">K / D / A：{{item.kdaText}}</view>
          <view wx:if="{{detail.imported}}" class="economy-row">
            <text>GPM {{item.gpmText}}</text>
            <text>XPM {{item.xpmText}}</text>
          </view>
          <view wx:else class="player-meta">{{item.assignedPosition ? item.assignedPosition + '号位 · ' : ''}}自评分 {{item.score}}</view>
        </view>
      </view>
    </view>

    <view class="section team-card dire">
      <view class="team-head">
        <text>夜魇</text>
        <text class="team-score">自评 {{detail.direScore}}</text>
        <text wx:if="{{detail.winnerSide === 'dire' || (detail.imported && !detail.radiantWin)}}" class="badge red">胜利</text>
      </view>
      <view wx:for="{{detail.dire}}" wx:key="playerId" class="player-row">
        <image wx:if="{{detail.imported}}" class="hero-portrait" src="{{item.heroImage}}" mode="aspectFill"></image>
        <image class="player-avatar" src="{{item.avatarSrc}}" mode="aspectFill"></image>
        <view class="player-main">
          <view class="player-name">{{detail.imported ? item.heroName : item.name}}</view>
          <view wx:if="{{detail.imported}}" class="player-meta">{{item.name}} · 自评分 {{item.score}}</view>
          <view wx:if="{{detail.imported}}" class="player-meta">K / D / A：{{item.kdaText}}</view>
          <view wx:if="{{detail.imported}}" class="economy-row">
            <text>GPM {{item.gpmText}}</text>
            <text>XPM {{item.xpmText}}</text>
          </view>
          <view wx:else class="player-meta">{{item.assignedPosition ? item.assignedPosition + '号位 · ' : ''}}自评分 {{item.score}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
