.primary-btn {
  margin-top: 16rpx;
}

.result-actions {
  display: grid;
  gap: 16rpx;
}

.result-actions .danger-btn,
.result-actions .primary-btn {
  margin-top: 0;
}

.lineup-grid {
  display: grid;
  gap: 20rpx;
  margin-top: 22rpx;
}

.lineup-column {
  padding: 18rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.035);
}

.radiant-column {
  border: 2rpx solid rgba(65, 176, 255, 0.34);
}

.dire-column {
  border: 2rpx solid rgba(230, 57, 70, 0.38);
}

.blue-title {
  color: #69c2ff;
}

.red-title {
  color: #ff7c87;
}

.lineup-picker,
.import-picker {
  display: flex;
  align-items: center;
  min-height: 70rpx;
  margin-top: 12rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 8rpx;
  color: #fffaf0;
  background: rgba(0, 0, 0, 0.2);
  font-size: 25rpx;
}

.lineup-slot {
  flex-shrink: 0;
  color: #9f9483;
}

.lineup-name {
  overflow: hidden;
  margin-left: 18rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.temporary-btn {
  margin-top: 18rpx;
}

.member-notice {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  color: #c9bdab;
  background: rgba(244, 196, 48, 0.08);
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
}

.match-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.match-main {
  flex: 1;
  min-width: 0;
}

.match-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  gap: 12rpx;
}

.mini-btn {
  height: 52rpx;
  min-width: 96rpx;
  padding: 0 18rpx;
  font-size: 22rpx;
  line-height: 52rpx;
}

.input {
  margin-top: 16rpx;
}

.import-preview {
  margin-top: 24rpx;
}

.team-preview {
  margin-top: 22rpx;
}

.team-title {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.import-player-row {
  padding: 18rpx 0;
  border-top: 2rpx solid rgba(255, 255, 255, 0.07);
}

.import-player-row:first-of-type {
  border-top: 0;
}

.import-player-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.import-picker {
  width: 100%;
}

.row-temp-btn {
  height: 60rpx;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 60rpx;
}
