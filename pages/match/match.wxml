<view class="screen">
  <view class="hero">
    <view class="eyebrow">ADMIN SCORE</view>
    <view class="title">秘马战绩录入</view>
    <view class="subtitle">第一版提供快速模拟录入：默认天辉获胜、天辉一号位 MVP、夜魇随机吃一条压力扣分。</view>
  </view>

  <view class="section panel">
    <view class="section-title">当前分队</view>
    <view wx:if="{{!teams}}" class="subtitle">请先去“开C”页完成系统分队。</view>
    <button wx:if="{{teams}}" class="primary-btn" bindtap="recordRadiantWin">录入天辉胜利</button>
  </view>

  <view class="section">
    <view class="section-title">最近战绩</view>
    <view wx:for="{{matches}}" wx:key="id" class="player-row panel">
      <view>
        <view class="player-name">{{item.title}}</view>
        <view class="player-meta">胜方 {{item.winner}} / MVP {{item.mvp}}</view>
      </view>
      <text class="badge">差 {{item.scoreGap}}</text>
    </view>
  </view>
</view>
