<view class="screen">
  <view class="hero">
    <view class="eyebrow">MIMA DOTA2 INHOUSE</view>
    <view class="title">秘马群内战控制台</view>
    <view class="subtitle">今晚开 C、自动分队、选手卡、积分榜和战绩录入都放在这里。</view>
  </view>

  <view class="section grid-3">
    <view class="stat">
      <view class="stat-value">{{room.signups.length}}</view>
      <view class="stat-label">正式报名</view>
    </view>
    <view class="stat">
      <view class="stat-value">{{waitlistCount}}</view>
      <view class="stat-label">候补</view>
    </view>
    <view class="stat">
      <view class="stat-value">{{room.startTime}}</view>
      <view class="stat-label">开 C 时间</view>
    </view>
  </view>

  <view class="section panel featured-panel">
    <view class="section-title">
      <text>{{room.title}}</text>
      <text class="badge">{{room.status}}</text>
    </view>
    <view class="subtitle">十人到齐后，在“开 C”页按自评分和偏好位置自动分队；满员后会自动进入候补名单。</view>
    <button class="primary-btn" bindtap="goRoom">进入开 C</button>
  </view>

  <view class="section">
    <view class="section-title">秘马前三卡片</view>
    <view wx:if="{{!topPlayers.length}}" class="empty-panel">还没有完整选手卡，先去“我的”创建自己的选手卡。</view>
    <view wx:for="{{topPlayers}}" wx:key="id" class="player-row panel">
      <image class="avatar-small" src="{{item.avatarSrc}}" mode="aspectFill"></image>
      <view class="player-main">
        <view class="player-name">{{index + 1}}. {{item.name}}</view>
        <view class="player-meta">积分 {{item.points}} / 自评分 {{item.score}} / 胜率 {{item.winRate}}%</view>
      </view>
      <text class="badge">{{item.points}}</text>
    </view>
  </view>
</view>
