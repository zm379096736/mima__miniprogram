<view class="screen">
  <view class="hero">
    <view class="eyebrow">MIMA RANKING</view>
    <view class="title">秘马选手卡</view>
    <view class="subtitle">排行榜按比赛积分；自评分和位置偏好仅用于系统自动分队。</view>
  </view>

  <view class="section grid-3">
    <view wx:for="{{podium}}" wx:key="id" class="stat">
      <view class="stat-value">{{item.points}}</view>
      <view class="stat-label">{{index + 1}}. {{item.name}}</view>
    </view>
  </view>

  <view class="section panel score-table">
    <view class="section-title">
      <text>积分表</text>
      <text class="badge">胜 +2 · 负 -1</text>
    </view>
    <view class="score-table-row score-table-head">
      <text class="score-rank">排名</text>
      <text class="score-player">选手</text>
      <text class="score-record">胜 / 负</text>
      <text class="score-points">积分</text>
    </view>
    <view wx:if="{{!scoreRows.length}}" class="empty-table">暂无选手积分</view>
    <view wx:for="{{scoreRows}}" wx:key="id" class="score-table-row">
      <text class="score-rank">#{{index + 1}}</text>
      <view class="score-player score-player-main">
        <image class="score-avatar" src="{{item.avatarSrc}}" mode="aspectFill"></image>
        <text class="score-player-name">{{item.name}}</text>
      </view>
      <text class="score-record">{{item.wins}} / {{item.losses}}</text>
      <text class="score-points">{{item.points}}</text>
    </view>
  </view>

  <view wx:if="{{pigeonBoard.length}}" class="section panel">
    <view class="section-title">鸽子榜</view>
    <view wx:for="{{pigeonBoard}}" wx:key="id" class="player-row">
      <image class="avatar-small" src="{{item.avatarSrc}}" mode="aspectFill"></image>
      <view class="player-main">
        <view class="player-name">{{index + 1}}. {{item.name}}</view>
        <view class="player-meta">累计鸽子 {{item.pigeon}} 次</view>
      </view>
      <text class="badge">{{item.pigeon}}</text>
    </view>
  </view>

  <view class="section card-grid">
    <view wx:if="{{!players.length}}" class="empty-panel">暂无选手卡。让大家先去“我的”填写自评分和偏好位置。</view>
    <view wx:for="{{players}}" wx:key="id" class="player-card">
      <view class="card-top">
        <image class="avatar-mid" src="{{item.avatarSrc}}" mode="aspectFill"></image>
        <view class="card-name-block">
          <view class="rank-num">#{{index + 1}}</view>
          <view class="player-name">{{item.name}}</view>
        </view>
        <text class="badge">{{item.points}} 分</text>
      </view>
      <view class="score-line">
        <text class="score">{{item.points}}</text>
        <text class="muted">比赛积分</text>
      </view>
      <view class="player-meta">自评分 {{item.score}} / 偏好 {{item.positionText}}</view>
      <view class="card-stats">
        <view>场次 {{item.matches}}</view>
        <view>胜率 {{item.winRate}}%</view>
        <view>MVP {{item.mvp}}</view>
        <view>大触 {{item.touch}}</view>
        <view>鸽子 {{item.pigeon}}</view>
      </view>
    </view>
  </view>
</view>
