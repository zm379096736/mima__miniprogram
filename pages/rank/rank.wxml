<view class="screen">
  <view class="hero">
    <view class="eyebrow">MIMA RANKING</view>
    <view class="title">秘马选手卡</view>
    <view class="subtitle">每个选手一张卡片，积分和偏好位置会用于今日开 C 的系统自动分队。</view>
  </view>

  <view class="section grid-3">
    <view wx:for="{{podium}}" wx:key="id" class="stat">
      <view class="stat-value">{{item.score}}</view>
      <view class="stat-label">{{index + 1}}. {{item.name}}</view>
    </view>
  </view>

  <view class="section card-grid">
    <view wx:for="{{players}}" wx:key="id" class="player-card">
      <view class="card-top">
        <view>
          <view class="rank-num">#{{index + 1}}</view>
          <view class="player-name">{{item.name}}</view>
        </view>
        <text class="badge">{{item.tier}}</text>
      </view>
      <view class="score-line">
        <text class="score">{{item.score}}</text>
        <text class="muted">秘马积分</text>
      </view>
      <view class="player-meta">偏好 {{item.positionText}}</view>
      <view class="card-stats">
        <view>场次 {{item.matches}}</view>
        <view>胜率 {{item.winRate}}%</view>
        <view>鸽子 {{item.pigeon}}</view>
      </view>
    </view>
  </view>
</view>
