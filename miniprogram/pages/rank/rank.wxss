.card-grid {
  display: grid;
  gap: 18rpx;
}

.player-card {
  padding: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 16rpx;
  background: rgba(18, 19, 21, 0.68);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.28), inset 0 0 28rpx rgba(0, 168, 255, 0.06);
}

.card-top,
.card-stats,
.score-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rank-num {
  color: #f1c40f;
  font-size: 22rpx;
  font-weight: 900;
}

.score-line {
  margin: 18rpx 0 8rpx;
}

.score {
  color: #f1c40f;
  font-size: 58rpx;
  font-weight: 900;
  text-shadow: 0 0 18rpx rgba(241, 196, 15, 0.26);
}

.card-stats {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.06);
  color: #8d98a8;
  font-size: 22rpx;
}
