<view class="screen">
  <view class="hero">
    <view class="eyebrow">MIMA DOTA2 INHOUSE</view>
    <view class="title">秘马群内战控制台</view>
    <view class="subtitle">今晚开 C、自动均衡分队、选手卡片、积分榜和战绩录入都放在这里。</view>
  </view>

  <view class="section grid-3">
    <view class="stat">
      <view class="stat-value">{{room.signups.length}}</view>
      <view class="stat-label">报名人数</view>
    </view>
    <view class="stat">
      <view class="stat-value">{{leader.name}}</view>
      <view class="stat-label">当前榜首</view>
    </view>
    <view class="stat">
      <view class="stat-value">{{room.startTime}}</view>
      <view class="stat-label">预计开局</view>
    </view>
  </view>

  <view class="section panel">
    <view class="section-title">
      <text>{{room.title}}</text>
      <text class="badge">{{room.status}}</text>
    </view>
    <view class="subtitle">十人到齐后可以在“开C”页按选手积分和偏好位置自动分队。</view>
    <button class="primary-btn" bindtap="goRoom">进入今日开 C</button>
  </view>

  <view class="section">
    <view class="section-title">秘马前三卡片</view>
    <view wx:for="{{topPlayers}}" wx:key="id" class="player-row panel">
      <view>
        <view class="player-name">{{index + 1}}. {{item.name}}</view>
        <view class="player-meta">{{item.tier}} / 偏好 {{item.positionText}} / 胜率 {{item.winRate}}%</view>
      </view>
      <text class="badge">{{item.score}}</text>
    </view>
  </view>
</view>
