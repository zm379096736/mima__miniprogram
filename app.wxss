page {
  min-height: 100%;
  color: #f7f4ea;
  background:
    radial-gradient(circle at 12% 0%, rgba(244, 196, 48, 0.18), transparent 32%),
    radial-gradient(circle at 94% 12%, rgba(230, 57, 70, 0.16), transparent 30%),
    linear-gradient(180deg, #15110d 0%, #1b1712 46%, #0e0d0b 100%);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
picker {
  box-sizing: border-box;
}

.screen {
  min-height: 100vh;
  padding: 28rpx 24rpx 56rpx;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 28rpx;
  border: 2rpx solid rgba(244, 196, 48, 0.28);
  border-radius: 14rpx;
  background: linear-gradient(135deg, rgba(43, 35, 24, 0.92), rgba(18, 17, 15, 0.82));
  box-shadow: 0 18rpx 46rpx rgba(0, 0, 0, 0.34), inset 0 0 36rpx rgba(244, 196, 48, 0.08);
}

.hero::after {
  content: "";
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(230, 57, 70, 0.16);
}

.eyebrow {
  color: #f4c430;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.title {
  margin-top: 10rpx;
  color: #fffaf0;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.12;
}

.subtitle {
  margin-top: 12rpx;
  color: #b8ad9b;
  font-size: 26rpx;
  line-height: 1.55;
}

.section {
  margin-top: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
  color: #f4c430;
  font-size: 30rpx;
  font-weight: 900;
}

.panel,
.empty-panel {
  padding: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 14rpx;
  background: rgba(26, 24, 20, 0.78);
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.26);
}

.featured-panel {
  border-color: rgba(244, 196, 48, 0.24);
  background: linear-gradient(135deg, rgba(47, 38, 25, 0.9), rgba(26, 24, 20, 0.78));
}

.empty-panel {
  color: #b8ad9b;
  font-size: 26rpx;
  line-height: 1.5;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.stat {
  min-width: 0;
  padding: 18rpx 12rpx;
  border: 2rpx solid rgba(244, 196, 48, 0.14);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.045);
  text-align: center;
}

.stat-value {
  overflow: hidden;
  color: #fffaf0;
  font-size: 34rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-label {
  margin-top: 6rpx;
  color: #9f9483;
  font-size: 22rpx;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  align-items: center;
  display: flex;
  justify-content: center;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
}

.primary-btn::after,
.ghost-btn::after,
.danger-btn::after {
  border: 0;
}

.primary-btn {
  color: #15110d;
  background: linear-gradient(135deg, #f4c430, #ffe8a3);
  box-shadow: 0 12rpx 28rpx rgba(244, 196, 48, 0.22);
}

.ghost-btn {
  color: #fffaf0;
  border: 2rpx solid rgba(244, 196, 48, 0.36);
  background: rgba(244, 196, 48, 0.08);
}

.danger-btn {
  color: #fffaf0;
  background: linear-gradient(135deg, #e63946, #9d1f2b);
  box-shadow: 0 12rpx 28rpx rgba(230, 57, 70, 0.18);
}

.team-card {
  padding: 22rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
}

.team-card.radiant {
  border: 2rpx solid rgba(65, 176, 255, 0.42);
  box-shadow: inset 6rpx 0 0 #41b0ff;
}

.team-card.dire {
  border: 2rpx solid rgba(230, 57, 70, 0.46);
  box-shadow: inset 6rpx 0 0 #e63946;
}

.team-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.player-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.06);
}

.player-row:first-child {
  border-top: 0;
}

.player-name {
  overflow: hidden;
  color: #fffaf0;
  font-size: 28rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-meta {
  margin-top: 4rpx;
  color: #9f9483;
  font-size: 22rpx;
  line-height: 1.35;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  min-width: 68rpx;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  color: #15110d;
  background: #f4c430;
  font-size: 22rpx;
  font-weight: 900;
}

.badge.blue {
  color: #fffaf0;
  background: #2f9ee7;
}

.badge.red {
  color: #fffaf0;
  background: #e63946;
}

.input {
  width: 100%;
  height: 76rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #fffaf0;
  background: rgba(0, 0, 0, 0.22);
  font-size: 26rpx;
}

.muted {
  color: #9f9483;
}

.avatar-small {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  margin-right: 16rpx;
  border: 2rpx solid rgba(244, 196, 48, 0.44);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.player-main {
  flex: 1;
  min-width: 0;
}
