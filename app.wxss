page {
  min-height: 100%;
  color: #f6f8fb;
  background:
    radial-gradient(circle at 12% 8%, rgba(0, 168, 255, 0.18), transparent 34%),
    radial-gradient(circle at 88% 2%, rgba(255, 71, 87, 0.18), transparent 30%),
    linear-gradient(180deg, #111318 0%, #171a20 42%, #0d0f13 100%);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
picker {
  box-sizing: border-box;
}

.screen {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
}

.hero {
  padding: 28rpx 24rpx;
  border: 2rpx solid rgba(0, 168, 255, 0.34);
  border-radius: 16rpx;
  background: rgba(18, 19, 21, 0.72);
  box-shadow: 0 18rpx 46rpx rgba(0, 0, 0, 0.36), inset 0 0 36rpx rgba(0, 168, 255, 0.08);
}

.eyebrow {
  color: #f1c40f;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.12;
}

.subtitle {
  margin-top: 12rpx;
  color: #aab4c3;
  font-size: 26rpx;
  line-height: 1.5;
}

.section {
  margin-top: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  color: #f1c40f;
  font-size: 30rpx;
  font-weight: 900;
}

.panel {
  padding: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 16rpx;
  background: rgba(18, 19, 21, 0.68);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.28);
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.stat {
  padding: 16rpx 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.04);
  text-align: center;
}

.stat-value {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 4rpx;
  color: #8d98a8;
  font-size: 22rpx;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  height: 76rpx;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.primary-btn {
  color: #071018;
  background: linear-gradient(135deg, #f1c40f, #ffeaa7);
  box-shadow: 0 12rpx 28rpx rgba(241, 196, 15, 0.24);
}

.ghost-btn {
  color: #ffffff;
  border: 2rpx solid rgba(0, 168, 255, 0.56);
  background: rgba(0, 168, 255, 0.12);
}

.danger-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #ff4757, #d63031);
}

.team-card {
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
}

.team-card.radiant {
  border: 2rpx solid rgba(0, 168, 255, 0.5);
  box-shadow: inset 6rpx 0 0 #00a8ff;
}

.team-card.dire {
  border: 2rpx solid rgba(255, 71, 87, 0.5);
  box-shadow: inset 6rpx 0 0 #ff4757;
}

.team-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.player-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.06);
}

.player-name {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.player-meta {
  margin-top: 4rpx;
  color: #8d98a8;
  font-size: 22rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 68rpx;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 21rpx;
  color: #0d0f13;
  background: #f1c40f;
  font-size: 22rpx;
  font-weight: 900;
}

.badge.blue {
  color: #ffffff;
  background: #00a8ff;
}

.badge.red {
  color: #ffffff;
  background: #ff4757;
}

.input {
  width: 100%;
  height: 76rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.22);
  font-size: 26rpx;
}

.muted {
  color: #8d98a8;
}
